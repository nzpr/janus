# Janus daemon defaults
JANUS_PROXY_BIND=127.0.0.1:9080
JANUS_CONTROL_SOCKET=/tmp/janusd-control.sock
JANUS_DEFAULT_TTL_SECONDS=3600

# Host allowlist for proxy/tunnels
JANUS_ALLOWED_HOSTS=github.com,api.github.com,codeberg.org,api.cohere.ai
JANUS_GIT_HTTP_HOSTS=github.com,codeberg.org

# Default session capabilities (expand as needed per workload)
JANUS_DEFAULT_CAPABILITIES=http_proxy,git_http,git_ssh

# Git HTTP auth
# JANUS_GIT_HTTP_USERNAME=x-access-token
# JANUS_GIT_HTTP_PASSWORD=replace-me

# Git SSH auth (host ssh-agent socket)
# JANUS_GIT_SSH_AUTH_SOCK=/var/run/janus/ssh-agent.sock
# JANUS_GIT_SSH_PRIVATE_KEY_FILE=/run/secrets/janus_git_ssh_key

# Optional typed adapter defaults
# JANUS_POSTGRES_HOST=127.0.0.1
# JANUS_POSTGRES_PORT=5432
# JANUS_POSTGRES_USER=postgres
# JANUS_POSTGRES_DATABASE=postgres
# JANUS_POSTGRES_PASSWORD=replace-me
# JANUS_KUBECONFIG=/home/user/.kube/config

# UI
# JANUS_NO_BANNER=1
